{
  "name": "taller_reviews",
  "version": "1.0.0",
  "description": "Modulo para taller de aws con serverless para manejar las peticiones de las reseñas de los productos",
  "main": "index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "deploy:dev": "serverless deploy --stage develop --aws-profile serverless_user_personal",
    "remove:dev": "serverless remove --stage develop --aws-profile serverless_user_personal",
    "deploy:prod": "serverless deploy --stage prod --aws-profile serverless_user_personal",
    "remove:prod": "serverless remove --stage prod --aws-profile serverless_user_personal"
  },
  "keywords": [
    "AWS",
    "NODEJS",
    "SERVERLESS"
  ],
  "author": "Gabriel Campos",
  "license": "ISC",
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.2",
    "aws-lambda": "^1.0.7",
    "serverless": "^4.35.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.1048.0",
    "@aws-sdk/lib-dynamodb": "^3.1045.0",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "uuid": "^14.0.0"
  }
}
