// Archivo de configuración de TypeScript para el proyecto del API Gateway, definiendo las opciones de compilación, incluyendo el módulo, target, tipos, 
// y configuraciones de salida y raíz para organizar el código fuente y los archivos compilados.
{
  "compilerOptions": {
    "module": "nodenext",
    "target": "es2020",
    "types": [],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": "src"
  },

  "include": ["src/**/*"]
}
